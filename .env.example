# Backend
APP_ENV=development
TRUSTED_HOSTS=127.0.0.1,localhost
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_BYTES=20971520
MAX_DATASET_ROWS=250000
MAX_DATASET_COLUMNS=200
MAX_RESULT_ROWS=200
MAX_CONCURRENT_TASKS=2
TASK_TIMEOUT_SECONDS=120
EVENT_RETENTION_DAYS=7
# 0 disables automatic dataset deletion.
DATASET_RETENTION_DAYS=0
TRACE_INCLUDE_SAMPLE_DATA=false
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080,http://localhost:8080

# Required for shared or remote deployments. Local-only development may leave it empty.
AUTH_MODE=local
API_ACCESS_TOKEN=

# OIDC mode validates JWT signatures and derives tenant/user identity from claims.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_TENANT_CLAIM=tenant_id
OIDC_ALGORITHMS=RS256

# LLM is off by default. The app still works through deterministic rule-based routing.
USE_LLM=false
# openai | openai_compatible | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=
LLM_BASE_URL=

# Backwards-compatible OpenAI variable names.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
PROMPT_VERSION=rule-first-v1

# AgentOps token and cost estimates
DEFAULT_TOKEN_BUDGET=50000
INPUT_TOKEN_PRICE_PER_1K=0.00015
OUTPUT_TOKEN_PRICE_PER_1K=0.0006
